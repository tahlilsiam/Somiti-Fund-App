# ---------------------------------------------------------------------------
# Sophnochura Somiti — Environment Variables
# Copy this file to `.env.local` and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API Keys
# ---------------------------------------------------------------------------

# Public — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# Server-only — NEVER expose to the browser or commit a real value.
# Used in later phases for privileged admin actions (e.g. creating users).
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxx
